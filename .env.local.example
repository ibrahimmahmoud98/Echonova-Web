# ============================================================
# ECHONOVA STUDIO - Environment Variables
# ============================================================
# هذا قالب لملف .env.local
#
# طريقة الاستخدام:
#   1) انسخ هذا الملف باسم .env.local
#   2) ضع القيم الحقيقية مكان الـ placeholders
#   3) أعد تشغيل dev server (npm run dev)
#
# ⚠️  لا تشارك هذا الملف ولا ترفعه على GitHub.
#     ملف .env.local موجود في .gitignore لحماية المفاتيح.
# ============================================================


# ----------------------------------------
# Resend (إرسال البريد الإلكتروني)
# ----------------------------------------
# يستخدم في: app/api/send-email/route.ts
# تحصل عليه من: https://resend.com/api-keys
# الشكل: re_ يليه ~30-40 حرف/رقم
RESEND_API_KEY=re_paste_your_key_here


# ----------------------------------------
# Cloudinary (الصور والفيديو)
# ----------------------------------------
# يستخدم في: lib/cloudinary.ts
# تحصل عليه من: https://console.cloudinary.com/console
#
# Cloud Name (اسم الحساب — public، يبدأ بدون re_/سر)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=da1dtiu2x

# API Key (سرّي)
CLOUDINARY_API_KEY=your_cloudinary_api_key_here

# API Secret (سرّي جداً)
CLOUDINARY_API_SECRET=your_cloudinary_secret_here

# Apollo API Key
APOLLO_API_KEY=your_apollo_api_key_here

# Exa API Key
EXA_API_KEY=your_exa_api_key_here

# Hunter API Key
HUNTER_API_KEY=your_hunter_api_key_here

