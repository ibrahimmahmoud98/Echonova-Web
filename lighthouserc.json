{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready in|started server on",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/about",
        "http://localhost:3000/services",
        "http://localhost:3000/services/reels",
        "http://localhost:3000/services/reels?level=action",
        "http://localhost:3000/services/reels?level=magic",
        "http://localhost:3000/services/aura",
        "http://localhost:3000/services/cinema",
        "http://localhost:3000/services/whisper",
        "http://localhost:3000/articles",
        "http://localhost:3000/articles/ai-revolution-cinema",
        "http://localhost:3000/contact",
        "http://localhost:3000/privacy",
        "http://localhost:3000/terms"
      ],
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance":     ["warn",  { "minScore": 0.85 }],
        "categories:accessibility":   ["error", { "minScore": 0.90 }],
        "categories:best-practices":  ["warn",  { "minScore": 0.90 }],
        "categories:seo":             ["error", { "minScore": 0.95 }],
        "color-contrast":             "off",
        "csp-xss":                    "off",
        "unused-javascript":          ["warn", { "maxNumericValue": 200000 }],
        "uses-responsive-images":     "warn",
        "uses-text-compression":      "error",
        "render-blocking-resources":  "warn",
        "meta-description":           "error",
        "document-title":             "error",
        "html-has-lang":              "error",
        "html-lang-valid":            "error",
        "is-crawlable":               "error",
        "robots-txt":                 "error",
        "structured-data":            "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
